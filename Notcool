<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>For Maryam 💐</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  background: linear-gradient(135deg, #5a0f2e, #8b1e3f);
  color: #fff;
  text-align: center;
  overflow: hidden;
}
.container {
  padding: 30px 20px;
  position: relative;
  min-height: 80vh;
}
h1 {
  font-size: 2.5em;
  margin-bottom: 10px;
  animation: fadeIn 2s ease;
}
button {
  padding: 14px 26px;
  font-size: 1.1em;
  border: none;
  border-radius: 30px;
  margin: 10px;
  cursor: pointer;
  transition: all 0.3s ease;
}
#whatBtn {
  background: #f7a1c4;
  color: #5a0f2e;
}
#yesBtn {
  background: #ff4d6d;
  color: white;
}
#noBtn {
  background: #aaa;
  color: black;
  position: absolute;
}
.hidden { display: none; }
#letter {
  margin-top: 25px;
  font-size: 1em;
  line-height: 1.7;
  white-space: pre-wrap;
}
.bigBold {
  font-size: 1.8em;
  font-weight: 900;
  margin-top: 20px;
}
.shawarmaImg {
  width: 200px;
  margin-top: 15px;
  transform: scale(0);
  animation: zoomBounce 2s forwards;
}
@keyframes fadeIn { from { opacity:0; transform: translateY(20px);} to {opacity:1; transform:translateY(0);} }
@keyframes zoomBounce {
  0% { transform: scale(0); }
  60% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
/* Bouquet animation */
.bouquet { position:absolute; top:10%; left:-200px; font-size:3em; animation: moveBouquet 12s linear infinite;}
@keyframes moveBouquet { from { left:-200px;} to {left:110%;} }
/* Floating items */
.float { position:absolute; font-size:2.5em; animation: float 6s ease-in-out infinite;}
@keyframes float {0% {transform:translateY(0);} 50%{transform:translateY(-20px);} 100%{transform:translateY(0);}}
</style>
</head>
<body onclick="playMusic()">
<!-- Floating items -->
<div class="bouquet">💐💐💐</div>
<div class="float" style="top:70%; left:10%;">🍜</div>
<div class="float" style="top:75%; right:10%;">👠</div>

<div class="container" id="page1">
  <h1 id="title">Will u be</h1>
  <button id="whatBtn" onclick="reveal()">What?</button>
</div>

<div class="container hidden" id="page2">
  <h1 id="title2">Will u be my Jaan?</h1>
  <button id="yesBtn" onclick="showLetter()">Yes</button>
  <button id="noBtn">No</button>
  <div id="letter"></div>
</div>

<div class="container hidden" id="page3">
  <div class="bigBold">OK YOU ARE NOT COOL 😂</div>
  <div class="bigBold">Pappi nhi di na 😒</div>
  <div class="bigBold">Mere sath hamesha shawarma khane chlo gi na?</div>
  <img src="https://i.imgur.com/zi1ZV4Y.png" class="shawarmaImg" alt="Shawarma">
</div>

<audio id="music" loop>
  <source src="https://cdn.pixabay.com/audio/2022/03/15/audio_9c8c56e5c6.mp3" type="audio/mpeg">
</audio>

<script>
let clicks = 0;
let noScale = 1;

// Page1 "What?" button logic
function reveal() {
  clicks++;
  if (clicks >= 3) {
    document.getElementById("page1").classList.add("hidden");
    document.getElementById("page2").classList.remove("hidden");
    positionNo();
  }
}

// No button playful
function positionNo() {
  const no = document.getElementById("noBtn");
  no.style.top = Math.random() * 60 + 20 + "%";
  no.style.left = Math.random() * 60 + 20 + "%";
}
document.getElementById("noBtn").addEventListener("mouseenter", () => {
  noScale -= 0.08;
  const no = document.getElementById("noBtn");
  no.style.transform = `scale(${noScale})`;
  positionNo();
});
document.getElementById("noBtn").addEventListener("click", e => {
  e.preventDefault();
  positionNo();
});

// Yes button -> show emotional letter and go to page3
function showLetter() {
  const text = `Maryam...

Idk how to say this, but you have a complete different vibe with me,
muje esa lgta hai k me apse koi bhi baat krlo jo bhi bol lo ap un me se nhi jo judge kre.

You are truly a genuine, kind and the most beautiful person I've ever met.
Idk, muje kiu esa lgta apse baat krni hoti hr wakt apka wait krta rehta.

Even though baat krne k liye koi topic nhi hota,
mgr phr bhi apka ok ok not cool I'm cool bhi boht hota.

Apki presence se muje sukoon milta.
Ese k bs chat me bethe rhe koi topic bhi na ho mgr phr bhi araam hota.

I want to be your friend forever.
And I hope that you feel the same.

I'm sorry if I'm overwhelming ya agr ap tang ati.
Aur hn agr kbhi kuch bhi ho, meri zarurat ho — btana zarur.

Aur agr ye sab bura laga, ye site waghera,
to I'm really sorry.

One of the biggest things I'm scared of is losing you
aur mai nhi chahta ke kuch bhi badle hamare darmiyan.

Bs samajh jana.`;
  typeWriter(text, () => { document.getElementById("page2").classList.add("hidden"); document.getElementById("page3").classList.remove("hidden"); });
}

// Typing effect
function typeWriter(text, callback) {
  let i = 0;
  const speed = 25;
  const letter = document.getElementById("letter");
  letter.innerHTML = "";
  const interval = setInterval(() => {
    letter.innerHTML += text.charAt(i);
    i++;
    if (i >= text.length) {
      clearInterval(interval);
      if(callback) setTimeout(callback, 2000);
    }
  }, speed);
}

// Music
function playMusic() {
  document.getElementById("music").play();
}
</script>
</body>
</html>
